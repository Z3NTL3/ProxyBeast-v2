{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProxyBeast",
  "version": "0.1.0",
  "identifier": "com.z3ntl3.proxybeast",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProxyBeast",
        "width": 1000,
        "height": 700,
        "visible": false,
        "maximizable": false,
        "resizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ], "resources": [
      "config.json"
    ]
  }
}
