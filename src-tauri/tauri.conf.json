{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "proxybeast",
  "version": "0.1.0",
  "identifier": "com.z3ntl3.proxybeast",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProxyBeast",
        "width": 1000,
        "height": 700,
        "visible": false,
        "maximizable": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/logo.png", "icons/logo.ico"]
  }
}
